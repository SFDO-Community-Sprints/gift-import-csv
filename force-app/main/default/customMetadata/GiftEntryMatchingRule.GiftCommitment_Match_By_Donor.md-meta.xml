<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>GiftCommitment - Match by Donor</label>
    <protected>false</protected>
    <values>
        <field>TargetField__c</field>
        <value xsi:type="xsd:string">GiftCommitmentId</value>
    </values>
    <values>
        <field>TargetObject__c</field>
        <value xsi:type="xsd:string">GiftCommitment</value>
    </values>
    <values>
        <field>SoqlWhereClause__c</field>
        <!-- DonorId resolved from step 1; GiftReceivedDate used for date proximity -->
        <value xsi:type="xsd:string">DonorId = '{!GiftEntry.DonorId}' AND Status = 'Active'</value>
    </values>
    <values>
        <field>Priority__c</field>
        <value xsi:type="xsd:double">10</value>
    </values>
    <values>
        <field>Weight__c</field>
        <value xsi:type="xsd:double">1.0</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
